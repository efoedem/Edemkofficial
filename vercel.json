{
  "version": 2,
  "builds": [
    {
      "src": "QUIZ1/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "QUIZ1/wsgi.py"
    }
  ],
  "env": {
    "PYTHONPATH": ".",
    "CLOUDINARY_CLOUD_NAME": "@cloudinary_cloud_name",
    "CLOUDINARY_API_KEY": "@cloudinary_api_key",
    "CLOUDINARY_API_SECRET": "@cloudinary_api_secret",
    "POSTGRES_URL": "@postgres_url",
    "SECRET_KEY": "@secret_key"
  }
}