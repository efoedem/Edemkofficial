{
  "version": 2,
  "builds": [
    {
      "src": "QUIZ1/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "(.*)",
      "dest": "QUIZ1/wsgi.py"
    }
  ],
  "build": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "QUIZ1.settings"
    }
  }
}